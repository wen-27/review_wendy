USE Sistema_Medico;

DELIMITER //

CREATE PROCEDURE GenerarSeguimiento(IN cod_cita_base VARCHAR(10), IN meses INT)
BEGIN
    DECLARE i INT DEFAULT 1;
    
    -- El ciclo se repetirá la cantidad de meses que defina
    WHILE i <= meses DO
        -- Muestra cuándo debería ser la siguiente cita
        SELECT 
            cod_cita_base AS Cita_Origen,
            DATE_ADD('2024-05-10', INTERVAL i MONTH) AS Sugerencia_Fecha_Control,
            CONCAT('Control Mes ', i) AS Observacion;

        -- aumento obligatorio para que el ciclo avance
        SET i = i + 1;
    END WHILE;
END //

DELIMITER ;

CALL GenerarSeguimiento('C-001', 4);